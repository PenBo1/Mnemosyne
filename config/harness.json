{
  "pipeline": {
    "max_revision_loops": 3,
    "max_concurrent_books": 1,
    "default_model": "gpt-4o",
    "model_overrides": {
      "writer": "gpt-4o",
      "auditor": "gpt-4o-mini",
      "planner": "gpt-4o-mini"
    }
  },
  "agents": {
    "architect": {
      "role": "architect",
      "tools_allowed": ["read_file", "write_file", "list_files"],
      "tools_denied": ["bash"],
      "token_budget": 8000,
      "sandbox_policy": "restricted"
    },
    "planner": {
      "role": "planner",
      "tools_allowed": ["read_file", "list_files", "search_memory"],
      "tools_denied": ["write_file", "bash"],
      "token_budget": 6000,
      "sandbox_policy": "strict"
    },
    "composer": {
      "role": "composer",
      "tools_allowed": ["read_file", "list_files", "search_memory"],
      "tools_denied": ["write_file", "bash"],
      "token_budget": 10000,
      "sandbox_policy": "strict"
    },
    "writer": {
      "role": "writer",
      "tools_allowed": ["read_file", "list_files", "search_memory", "archive_memory"],
      "tools_denied": ["write_file", "bash"],
      "token_budget": 8000,
      "sandbox_policy": "restricted"
    },
    "auditor": {
      "role": "auditor",
      "tools_allowed": ["read_file", "list_files", "search_memory"],
      "tools_denied": ["write_file", "bash"],
      "token_budget": 10000,
      "sandbox_policy": "strict"
    },
    "reviser": {
      "role": "reviser",
      "tools_allowed": ["read_file", "list_files", "search_memory"],
      "tools_denied": ["bash"],
      "token_budget": 8000,
      "sandbox_policy": "restricted"
    },
    "observer": {
      "role": "observer",
      "tools_allowed": ["read_file", "search_memory", "archive_memory"],
      "tools_denied": ["write_file", "bash"],
      "token_budget": 4000,
      "sandbox_policy": "strict"
    },
    "reflector": {
      "role": "reflector",
      "tools_allowed": ["read_file", "search_memory", "archive_memory"],
      "tools_denied": ["write_file", "bash"],
      "token_budget": 4000,
      "sandbox_policy": "strict"
    }
  },
  "quality": {
    "min_audit_score": 70.0,
    "max_critical_issues": 0,
    "word_count_variance_pct": 15.0
  },
  "gc_policy": {
    "stale_snapshot_days": 30,
    "gc_interval_chapters": 10
  }
}
