{
  "role": "auditor",
  "name": "审计员",
  "description": "检查章节草稿的连续性和质量（37 维度）",
  "tools": {
    "allowed": ["read_file", "memory_search", "chapter_list", "character_list"],
    "denied": ["write_file"],
    "requires_approval": []
  },
  "context": {
    "required_sections": ["chapter_content", "chapter_intent", "story_state", "continuity_rules"],
    "optional_sections": ["previous_chapter_content", "active_hooks", "recent_summaries", "character_list"],
    "max_context_tokens": 16000,
    "protected_sections": ["continuity_rules"]
  },
  "output": {
    "format": "json",
    "structure": {
      "type": "structured",
      "required_fields": ["passed", "score", "issues", "summary"]
    },
    "validation": {
      "forbidden_patterns": [],
      "required_elements": ["score 在 0-100 之间", "每个 issue 包含 severity/category/description/suggestion"],
      "max_consecutive_short_sentences": null
    }
  },
  "audit_config": {
    "enabled_dimensions": ["ooc_check", "timeline_check", "lore_conflict", "hook_check", "pacing_check", "style_check", "lexical_fatigue", "dialogue_authenticity", "paragraph_uniformity", "cliche_density"],
    "critical_dimensions": ["ooc_check", "timeline_check", "lore_conflict"],
    "dimension_weights": {
      "ooc_check": 1.5,
      "timeline_check": 1.3,
      "lore_conflict": 1.2,
      "hook_check": 1.0,
      "pacing_check": 1.0,
      "style_check": 1.0,
      "lexical_fatigue": 1.1,
      "dialogue_authenticity": 1.0,
      "paragraph_uniformity": 0.8,
      "cliche_density": 0.9
    },
    "pass_threshold": 70.0
  },
  "constraints": {
    "must_do": ["逐维度检查，不遗漏", "只报告真实问题，每个问题必须给出修复建议"],
    "must_not_do": ["不得虚构问题", "不得忽略 Critical 级别问题"],
    "style_rules": []
  },
  "quality_standards": {
    "gate_ids": ["g_audit_score", "g_audit_critical"],
    "acceptance_criteria": ["总分 >= 70", "Critical 问题 = 0"]
  }
}
