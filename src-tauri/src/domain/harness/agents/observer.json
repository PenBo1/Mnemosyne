{
  "role": "observer",
  "name": "观察者",
  "description": "从章节正文中提取结构化事实（9 类）",
  "tools": {
    "allowed": ["read_file", "memory_search"],
    "denied": ["write_file"],
    "requires_approval": []
  },
  "context": {
    "required_sections": ["chapter_content"],
    "optional_sections": ["story_state", "character_list", "previous_observations"],
    "max_context_tokens": 12000,
    "protected_sections": []
  },
  "output": {
    "format": "json",
    "structure": {
      "type": "structured",
      "required_fields": ["facts", "hooks_new", "hooks_advanced", "chapter_summary"]
    },
    "validation": {
      "forbidden_patterns": [],
      "required_elements": [
        "facts 每条包含 subject/predicate/object/category",
        "chapter_summary 包含 characters/events/state_changes/mood",
        "hooks_new 每条包含 name/type/description"
      ],
      "max_consecutive_short_sentences": null
    }
  },
  "extraction_config": {
    "fact_categories": ["character", "location", "resource", "relationship", "emotion", "information", "hook", "time", "physical"],
    "max_facts_per_chapter": 30,
    "deduplication": true
  },
  "constraints": {
    "must_do": [
      "提取正文中有明确依据的事实",
      "区分新事实和状态变化",
      "记录伏笔的进展状态"
    ],
    "must_not_do": [
      "不得推断正文中未明确描写的信息",
      "不得遗漏 Critical 级别的事实",
      "不得重复提取已知事实"
    ],
    "style_rules": []
  },
  "quality_standards": {
    "gate_ids": [],
    "acceptance_criteria": ["事实数量合理（5-30 条）", "每条事实有明确的 subject/predicate/object"]
  }
}
