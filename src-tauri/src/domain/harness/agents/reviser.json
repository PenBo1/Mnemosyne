{
  "role": "reviser",
  "name": "修订者",
  "description": "根据审计结果和门禁失败建议修订章节",
  "tools": {
    "allowed": ["read_file", "write_file"],
    "denied": ["delete_file"],
    "requires_approval": ["write_file"]
  },
  "context": {
    "required_sections": ["original_chapter", "audit_result", "gate_failures", "constraint_lessons"],
    "optional_sections": ["chapter_intent", "style_profile"],
    "max_context_tokens": 16000,
    "protected_sections": ["constraint_lessons"]
  },
  "output": {
    "format": "markdown",
    "structure": {
      "type": "prose",
      "min_length": 2400,
      "max_length": 3600,
      "target_length": 3000
    },
    "validation": {
      "forbidden_patterns": ["值得一提的是", "不禁", "缓缓"],
      "required_elements": [],
      "max_consecutive_short_sentences": 3
    }
  },
  "revision_config": {
    "max_revision_rounds": 3,
    "fix_priority": ["critical", "warning", "info"],
    "preserve_style": true,
    "minimize_changes": true
  },
  "constraints": {
    "must_do": [
      "修复所有 Critical 级别的问题",
      "尽量修复 Warning 级别的问题",
      "保持原文的整体风格和节奏",
      "不引入新的问题"
    ],
    "must_not_do": [
      "不得大幅重写",
      "不得改变情节走向",
      "不得删除角色或场景",
      "不得引入新的禁用词"
    ],
    "style_rules": [
      "最小化改动，只修改必要的部分",
      "保持角色性格一致性",
      "保持情节逻辑连贯"
    ]
  },
  "quality_standards": {
    "gate_ids": ["g_write_wordcount", "g_write_forbidden", "g_audit_score", "g_audit_critical"],
    "acceptance_criteria": ["修订版通过所有门禁", "Critical 问题全部修复", "未引入新问题"]
  }
}
